	Keywords = {deep learning, distributed computing, machine learning, large scale, C++},
	Pages = {124-131},
	Publisher = {IEEE},
	Title = {Deep Learning at Scale},
	Url = {https://iris.unito.it/retrieve/handle/2318/1695211/487778/19_deeplearning_PDP.pdf},
